# Copy this file to .env and fill in your own local paths.
# cp .env.example .env

# Root directory for all pipeline data (CAD/OBJ files, renders, trained
# models, embeddings). Used by convert_cad_to_obj.py, generate_synthetic_dataset.py,
# train_yolo.py, build_index_with_dino_and_faiss.py
# Expected subfolders created/used under this path: dxf/, obj/, raw/, dataset/, models/, embeddings/
MODEL_DATA_DIR=/absolute/path/to/model_data

# Number of synthetic renders to generate per object.
# Used by generate_synthetic_dataset.py
# Optional — defaults to 300 if not set.
MODEL_DATA_NUM_RENDERS=300

# Directory containing raw (uncomposited) renders, used when preparing
# the dataset for YOLO training.
# Used by prepare_dataset_for_yolo.py
RAW_DATA_DIR=/absolute/path/to/raw_data

# Directory where the prepared YOLO dataset (train/val split, dataset.yaml)
# will be written.
# Used by prepare_dataset_for_yolo.py
OUTPUT_DATA_DIR=/absolute/path/to/output_data

# Directory containing real-world background photos used to composite
# renders onto during dataset preparation.
# Used by prepare_dataset_for_yolo.py
BACKGROUNDS_DIR=/absolute/path/to/backgrounds